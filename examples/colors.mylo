mod term {

    enum Colour {
        Black,
        Red,
        Green,
        Yellow,
        Blue,
        Magenta,
        Cyan,
        White
    }
	
    // Define an instance of each enum to use
    // without ::
    var BLACK : Colour = Colour::Black
    var RED : Colour = Colour::Red
    var GREEN : Colour = Colour::Green
    var YELLOW : Colour = Colour::Yellow
    var BLUE   : Colour = Colour::Blue
    var MAGENTA : Colour = Colour::Magenta
    var CYAN : Colour = Colour::Cyan
    var WHITE : Colour = Colour::White

    // Takes forground and background colour and 
    // returns the escape string
    fn cformat(text: str, fg : Colour, bg: Colour) {
        var fg_code : i32 = (fg + 30)
        var bg_code : i32 = (bg + 40)
        
        var start_code = f"[{fg_code};{bg_code}m"
        var reset_code = "[0m"
        ret start_code + text + reset_code
    }
}

// Tada!
print(term::cformat("Success!", term::BLUE, term::GREEN))
